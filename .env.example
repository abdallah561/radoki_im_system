# Django Settings
# For production: DEBUG=False
# Generate a new SECRET_KEY using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DEBUG=False
SECRET_KEY=your-secret-key-here

# Database Configuration (using DATABASE_URL format)
# Local development: postgresql://postgres:password@localhost:5432/radoki_db
# Production (Neon/DigitalOcean/etc): postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/radoki_db
DATABASE_SSL_MODE=require

# Allowed hosts for production (comma-separated, no spaces)
# Development: localhost,127.0.0.1
# Production: radoki-im-system.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1,radoki-im-system.onrender.com

# CSRF & Security Settings
CSRF_TRUSTED_ORIGINS=https://127.0.0.1:8000,https://localhost:8000,https://radoki-im-system.onrender.com

# Email Configuration (Resend HTTP API - Recommended for Render)
EMAIL_BACKEND=core.email_backends.ResendEmailBackend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@your-verified-domain.com
DEFAULT_FROM_EMAIL=noreply@your-verified-domain.com

# Legacy SMTP Configuration (Optional - only if you prefer SMTP)
# To use SMTP instead of HTTP API, set: EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USE_TLS=True
# SMTP_USE_SSL=False
# SMTP_TIMEOUT=10
# SMTP_USER=resend
# SMTP_PASSWORD=your-resend-api-key
# SMTP_FROM_EMAIL=noreply@your-verified-domain.com

# Cloudflare R2 Configuration (for production media storage - REQUIRED IN PRODUCTION)
# All user uploads, documents, and media files are stored in R2 exclusively.
# Create an R2 bucket in Cloudflare console: https://dash.cloudflare.com/
# Create API token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=your-r2-bucket-name
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
# Optional: custom public domain for R2 objects (e.g., cdn.yourdomain.com)
# If not set, defaults to: {BUCKET_NAME}.{ACCOUNT_ID}.r2.cloudflarestorage.com
CLOUDFLARE_R2_CUSTOM_DOMAIN=your-custom-domain.com
# Optional: override endpoint if using a nonstandard Cloudflare R2 endpoint
CLOUDFLARE_R2_ENDPOINT_URL=
